{
  "name": "landa",
  "version": "0.17.0",
  "description": "Talk into any app. Landa types it for you — formatted, polished, and private.",
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "dev": "ELECTRON_RUN_AS_NODE= electron . --dev",
    "build": "electron-builder",
    "build:mac": "bash scripts/build_backend.sh && electron-builder --mac",
    "build:mac:notarized": "bash scripts/build_backend.sh && LANDA_REQUIRE_NOTARIZATION=1 electron-builder --mac",
    "notary:status": "node scripts/notary-status.js",
    "build:win": "powershell -ExecutionPolicy Bypass -File scripts\\build_backend.ps1 && electron-builder --win"
  },
  "build": {
    "appId": "com.landa.app",
    "productName": "Landa",
    "publish": {
      "provider": "github",
      "owner": "nickybricks",
      "repo": "landa"
    },
    "beforeBuild": "scripts/before_build.js",
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "signIgnore": [
        "\\.pak$"
      ],
      "entitlements": "entitlements/entitlements.mac.plist",
      "entitlementsInherit": "entitlements/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Landa needs microphone access to record your voice for speech-to-text transcription.",
        "NSAccessibilityUsageDescription": "Landa needs accessibility access to paste transcribed text into the active application."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist/landa_backend",
        "to": "backend/landa_backend"
      },
      {
        "from": "backend/landa_core.py",
        "to": "backend/landa_core.py"
      },
      {
        "from": "backend/requirements.txt",
        "to": "backend/requirements.txt"
      }
    ]
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
