# Local-dev only. Production builds bake these into backend/landa_constants.py
# at build time via GitHub Actions secrets.
#
# Copy to .env (gitignored) and fill in real values:
#   - LANDA_PROXY_URL: production alias of the deployed landa-proxy
#   - LANDA_APP_SECRET: the bearer secret you generated for the proxy

LANDA_PROXY_URL=https://landa-proxy.vercel.app
LANDA_APP_SECRET=
